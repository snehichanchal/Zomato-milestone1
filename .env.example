# Groq LLM Configuration
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant
GROQ_TEMPERATURE=0.3

# Hugging Face Dataset
HF_DATASET_NAME=ManikaSaini/zomato-restaurant-recommendation

# Application Settings
MAX_CANDIDATES_FOR_LLM=20
TOP_K_RECOMMENDATIONS=5
DATA_CACHE_PATH=data/restaurants_cache.csv

# Budget Thresholds (INR)
BUDGET_LOW_MAX=500
BUDGET_MEDIUM_MAX=1500

# CORS — comma-separated list of allowed frontend origins
# For production, add your Vercel URL here
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Port (Railway injects this automatically)
PORT=8000
